{
  "name": "geek_zone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:e2e": "cypress run",
    "deploy": "vue-cli-service build && echo www.geekzone.site > dist/CNAME && gh-pages -d dist -b gh-pages --no-history -m \"chore(deploy): v$npm_config_version\"",
    "push": "git add . && git commit -m \"$npm_config_message\" && git push"
  },
  "dependencies": {
    "core-js": "^3.8.3",
    "firebase": "^11.2.0",
    "vue": "^3.2.13",
    "vue-router": "^4.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^13.17.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "gh-pages": "^6.3.0",
    "jsdom": "^24.1.3",
    "vitest": "^2.1.9"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "globals": {
      "describe": "readonly",
      "it": "readonly",
      "expect": "readonly",
      "vi": "readonly"
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
